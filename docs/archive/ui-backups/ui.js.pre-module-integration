function showExecutionIndicator(state) {
  const indicator = document.getElementById('execution-indicator');
  if (!indicator) return;

  // Remove all state classes
  indicator.className = 'star-container';

  // Add new state
  if (state && state !== 'idle') {
    indicator.classList.add(`star-${state}`);
    indicator.classList.remove('hidden');

    // Create particles for executing state
    if (state === 'executing') {
      createStarParticles();
    }
  } else {
    indicator.classList.add('hidden');
  }

  scrollChatToBottom();
}

function hideExecutionIndicator() {
  const indicator = document.getElementById('execution-indicator');
  if (indicator) {
    indicator.classList.add('hidden');
  }
}

function createStarParticles() {
  const field = document.getElementById('particle-field');
  if (!field) return;

  // Create 3 particles
  for (let i = 0; i < 3; i++) {
    setTimeout(() => {
      const particle = document.createElement('div');
      particle.className = 'star-particle';

      // Random direction
      const angle = Math.random() * Math.PI * 2;
      const distance = 15 + Math.random() * 10;
      const px = Math.cos(angle) * distance;
      const py = Math.sin(angle) * distance;

      particle.style.setProperty('--px', `${px}px`);
      particle.style.setProperty('--py', `${py}px`);
      particle.style.left = '50%';
      particle.style.top = '50%';

      field.appendChild(particle);

      // Remove after animation
      setTimeout(() => particle.remove(), 2000);
    }, i * 400);
  }
}
