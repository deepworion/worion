          <button class="${destructive ? 'btn-danger' : 'btn-primary'}" id="confirm-action-btn">${escapeHtml(confirmLabel)}</button>
        </div>
      </div>`;
    modal.addEventListener('click', () => {
      closeConfirmModal();
      resolve(false);
    });
