  const cleanQuestion = String(question || '').trim();
  const cleanSelection = String(selectionText || '').trim();
  const instruction = cleanQuestion || 'Explique este trecho.';
  return [
    instruction,
    '',
    'Trecho selecionado:',
    '```text',
    cleanSelection,
    '```'
  ].join('\n');
}

