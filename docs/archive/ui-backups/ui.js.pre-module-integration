function updateExecutionStatus() {
  const status = document.getElementById('executionStatus');
  if (!status) return;
  const label = getFriendlyExecutionLabel();
  const labelEl = document.getElementById('executionStatusLabel') || status.querySelector('.execution-label');
  if (labelEl) labelEl.textContent = label;
  const trail = Array.isArray(executionStatusTrail) ? executionStatusTrail.slice(-4) : [];
  let trailEl = status.querySelector('.execution-trail');
  if (trail.length && !trailEl) {
    trailEl = document.createElement('div');
    trailEl.className = 'execution-trail';
    status.appendChild(trailEl);
  }
  if (trailEl) {
    trailEl.innerHTML = trail.map(item => `<span>${escapeHtml(item)}</span>`).join('');
    trailEl.style.display = trail.length ? 'flex' : 'none';
  }
  status.classList.toggle('active', Boolean(label));
}

function showExecutionStatus(label) {
  if (!isAssistantResponding) return;
  executionStatusLabel = label || TOOL_STATUS_LABELS?.default || 'Processando...';
  if (!Array.isArray(executionStatusTrail)) executionStatusTrail = [];
  if (executionStatusLabel && executionStatusTrail[executionStatusTrail.length - 1] !== executionStatusLabel) {
    executionStatusTrail.push(executionStatusLabel);
    executionStatusTrail = executionStatusTrail.slice(-6);
  }
  updateExecutionStatus();
  if (typeof showExecutionIndicator === 'function') {
    const isToolAction = /buscando|consultando|pesquisando|criando|gerando|executando|validando|abrindo/i.test(executionStatusLabel);
    showExecutionIndicator(isToolAction ? 'executing' : 'thinking');
  }
}

